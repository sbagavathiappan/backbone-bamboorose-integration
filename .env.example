# =============================================================
# Backbone PLM to Bamboo Rose Integration - Environment Variables
# =============================================================
# Copy this file to .env and fill in the values.
# Usage: source .env   (Linux/macOS)
#        Get-Content .env | ForEach-Object { [System.Environment]::SetEnvironmentVariable($_.Split('=')[0], $_.Split('=')[1]) }  (Windows PowerShell)

# --- Application ---
SPRING_PROFILES_ACTIVE=dev

# --- Webhook Security ---
# Shared secret for HMAC-SHA256 signature validation
WEBHOOK_SECRET=your-secure-random-secret-here

# --- Backbone PLM API ---
BACKBONE_PLM_URL=https://api.backboneplm.com
BACKBONE_API_KEY=your-backbone-api-key

# --- Bamboo Rose API ---
BAMBOO_ROSE_URL=https://api.bamboorose.com
BAMBOO_ROSE_API_KEY=your-bamboo-rose-api-key
BAMBOO_ROSE_API_SECRET=your-bamboo-rose-api-secret

# --- Database (Production - PostgreSQL) ---
# Uncomment and configure for production use
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/webhookdb
# SPRING_DATASOURCE_USERNAME=webhook_user
# SPRING_DATASOURCE_PASSWORD=your-db-password

# --- Server ---
SERVER_PORT=8080
