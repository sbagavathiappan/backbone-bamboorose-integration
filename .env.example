# =============================================================
# BKBN to Bamboo Rose Integration - Environment Variables
# =============================================================
# Copy this file to .env and fill in the values.

# --- Application ---
SPRING_PROFILES_ACTIVE=dev

# --- Webhook Security ---
# Shared secret for BKBN webhook authentication (Bearer token validation)
WEBHOOK_SECRET=your-secure-bearer-token-here

# --- BKBN Sync API ---
BKBN_BASE_URL=https://sync.bkbn.com
BKBN_CLIENT_ID=your-bkbn-client-id
BKBN_CLIENT_SECRET=your-bkbn-client-secret

# --- Bamboo Rose API ---
BAMBOO_ROSE_URL=https://api.bamboorose.com
BAMBOO_ROSE_API_KEY=your-bamboo-rose-api-key
BAMBOO_ROSE_API_SECRET=your-bamboo-rose-api-secret

# --- Database (Production - PostgreSQL) ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/webhookdb
# SPRING_DATASOURCE_USERNAME=webhook_user
# SPRING_DATASOURCE_PASSWORD=your-db-password

# --- Server ---
SERVER_PORT=8080
